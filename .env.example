# PHYLAX — environment shape. Copy to .env.local and fill in. NEVER commit .env.local.
# The InsForge CLI writes base URL / API key / anon key when you create or link a project;
# `npm run seed:users` and the host read these values.

# InsForge project (from .insforge/project.json — auto-provisioned to edge functions)
INSFORGE_BASE_URL=https://<appkey>.us-east.insforge.app
API_KEY=<project-admin-api-key>          # full-access; server-only, never in the browser
INSFORGE_ANON_KEY=anon_<...>             # browser-safe anon key
VITE_INSFORGE_URL=https://<appkey>.us-east.insforge.app
VITE_INSFORGE_ANON_KEY=anon_<...>

# Signing secrets — also set as InsForge secrets (secrets add ...). Must match.
WORKER_HMAC_SECRET=<hex 64>              # authenticates coordinator → receive-worker-callback
RECEIPT_SIGNING_KEY=<hex 64>             # signs + verifies incident receipts

# Party-compute config
PHYLAX_JOINT_SECRET=<hex 48>             # derives the jointly-governed OPRF key
PHYLAX_PSI_BACKEND=modp-ddh              # modp-ddh (stdlib, default) | secretflow (Docker/SPU)

# Demo only
PHYLAX_DEMO_PASSWORD=phylax-demo-2026
PORT=8890
